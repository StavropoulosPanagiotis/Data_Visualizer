  <step>
    <name>Normalize Nulls - Inproceedings</name>
    <type>IfNull</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <typeonlyused>N</typeonlyused>
    <replaceAllByValue/>
    <replaceAllMask/>
    <setEmptyStringAll>N</setEmptyStringAll>
    <fields>
      <field>
        <name>author</name>
        <value/>
        <mask/>
        <set_empty_string>N</set_empty_string>
