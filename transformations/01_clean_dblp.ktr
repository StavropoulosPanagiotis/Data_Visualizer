    <valueTypes/>
    <GUI><xloc>320</xloc><yloc>320</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Filter Invalid Inproceedings</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <send_true_to>Write Cleaned Inproceedings</send_true_to>
    <send_false_to/>
    <compare>
      <!-- Keep rows where NOT (author = '' AND year = '') -->
      <condition>
        <negated>Y</negated>
        <conditions>
          <condition>
            <negated>N</negated>
            <operator>-</operator>
            <leftvalue>author</leftvalue>
            <function>=</function>
            <rightvalue/>
            <value>
              <name>constant</name>
              <type>String</type>
              <text/>
              <length>-1</length>
              <precision>-1</precision>
              <isnull>N</isnull>
              <mask/>
            </value>
          </condition>
          <condition>
            <negated>N</negated>
            <operator>AND</operator>
            <leftvalue>year</leftvalue>
            <function>=</function>
            <rightvalue/>
            <value>
              <name>constant</name>
              <type>String</type>
              <text/>
              <length>-1</length>
              <precision>-1</precision>
              <isnull>N</isnull>
              <mask/>
            </value>
          </condition>
        </conditions>
      </condition>
    </compare>
    <GUI><xloc>540</xloc><yloc>320</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Write Cleaned Inproceedings</name>
    <type>TextFileOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>C:/Users/Administrator/Desktop/Projects/Data_Visualizer/cleaned_data/cleaned_inproceedings</filename>
    <create_parent_folder>Y</create_parent_folder>
    <servlet_output>N</servlet_output>
    <do_not_open_newfile_init>N</do_not_open_newfile_init>
    <extention>csv</extention>
    <append>N</append>
    <split>N</split>
    <haspartno>N</haspartno>
    <add_date>N</add_date>
    <add_time>N</add_time>
    <SpecifyFormat>N</SpecifyFormat>
    <date_time_format/>
    <add_to_result_filenames>Y</add_to_result_filenames>
    <zipped>N</zipped>
    <splitevery/>
    <encoding>UTF-8</encoding>
    <filecompression>None</filecompression>
    <header>Y</header>
    <footer>N</footer>
    <format>CR+LF</format>
    <compression>None</compression>
    <endedLine/>
    <fileNameInField>N</fileNameInField>
    <fileNameField/>
    <new_line>&#13;&#10;</new_line>
    <separator>;</separator>
    <enclosure>&quot;</enclosure>
    <enclosure_forced>N</enclosure_forced>
    <enclosure_fix_disabled>N</enclosure_fix_disabled>
    <fields>
      <field><name>id</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>author</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>booktitle</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>cdrom</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>cite</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>cite-label</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>crossref</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>editor</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>ee</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>i</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>key</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>mdate</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>month</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>note</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>number</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>pages</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>publtype</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>sub</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>sup</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>title</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>title-bibtex</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>tt</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>url</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
      <field><name>year</name><type>String</type><format/><currency/><decimal/><group/><nullif/><attribute>N</attribute><length>-1</length><precision>-1</precision></field>
    </fields>
    <GUI><xloc>760</xloc><yloc>320</yloc><draw>Y</draw></GUI>
  </step>

  <step_error_handling/>

  <order>
    <hop>
      <from>Read Articles</from>
      <to>Normalize Nulls - Articles</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
      <unconditional>Y</unconditional>
    </hop>
    <hop>
